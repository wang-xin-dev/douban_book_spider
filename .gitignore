# ============================================================
# GitHub 仓库 .gitignore
# 豆瓣高分图书爬虫项目
# ============================================================
# 作用：告诉 Git 哪些文件不需要上传到 GitHub
# 比如缓存文件、虚拟环境、IDE 配置等

# ---- Python 缓存 ----
__pycache__/
*.pyc
*.pyo

# ---- 虚拟环境 ----
venv/
.venv/
env/

# ---- IDE 配置 ----
.vscode/
.idea/

# ---- 系统文件 ----
.DS_Store
Thumbs.db
desktop.ini
